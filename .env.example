# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Transcription API Configuration (separate from main API)
# Used for voice message transcription with a dedicated model
TRANSCRIPTION_API_KEY=your_transcription_api_key_here
TRANSCRIPTION_MODEL=google/gemini-2.5-flash-preview-05-20

# Flask Configuration
FLASK_SECRET_KEY=your_secret_key_here
FLASK_ENV=development

# Optional: Default Model (can be changed in UI)
# Available models with reasoning: deepseek/deepseek-v3.2, openai/o3-mini, etc.
DEFAULT_MODEL=google/gemini-3.1-flash-lite-preview

# Minimax TTS Configuration
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_TTS_VOICE=Malay_male_1_v1
MINIMAX_TTS_LANGUAGE=Malay

# RAG System Configuration
ENABLE_RAG=true
RAG_TOP_K=5
# Set to 'true' only if you have sufficient RAM (8GB+) - downloads embedding model (~80MB)
RAG_USE_ADVANCED=false

# VTube Studio Integration Configuration
# Enable VTS integration for Live2D avatar lip sync
VTS_ENABLED=true
VTS_HOST=localhost
VTS_PORT=8001
VTS_AUTO_RECONNECT=true
VTS_RECONNECT_INTERVAL=5.0

# Human Detection Configuration (YOLOv8)
# Requires: pip install ultralytics opencv-python
DETECTION_ENABLED=true
DETECTION_CAMERA_INDEX=0
DETECTION_CONFIDENCE=0.5
DETECTION_MODEL=yolov8n.pt
DETECTION_GREETING_COOLDOWN=15.0
DETECTION_MIN_DURATION=1.5
DETECTION_AUTO_GREET=true
DETECTION_ZONE_ENABLED=true
